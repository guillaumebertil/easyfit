{% extends 'base.html.twig' %}

{% block title %}{{ title }} | EasyFit{% endblock %}

{% block body %}

{# Fil d'ariane #}
<div class="px-4 mb-4">
    <p><a href="{{ path('app_account') }}">< Retour au compte</a></p>
</div>

<div class="w-full px-4">
    <h1 class="text-4xl font-bold mb-4">Mes commandes</h1>

    {# Liste des commandes #}
    <div class="flex flex-col mb-4">
        {% if orders is empty %}
            <p class="text-gray-500">Vous n'avez pas encore passé de commande.</p>
        {% else %}
            {% for order in orders %}
                <div class="rounded-2xl my-4 border border-gray-200 p-4">

                    {# En-tête de la commande #}
                    <div class="text-2xl font-semibold mb-2">Commande N°{{ order.id }}</div>

                    <div class="text-sm text-text-main space-y-1">
                        <div><span class="font-semibold">Date :</span> {{ order.createdAt|date('d/m/Y') }}</div>
                        <div><span class="font-semibold">Total :</span> {{ order.total }}</div>
                        <div><span class="font-semibold">Statut :</span> {{ order.status.label }}</div>
                    </div>

                    {# Articles de la commande #}
                    <div class="mt-3">
                        <span class="font-semibold">Articles :</span>
                        <div class="ps-4 mt-1">
                            {% for item in order.orderItems %}
                                <div>
                                    <a href="{{ path('app_product_show', {
                                        categorySlug: item.productVariant.product.category.slug,
                                        slug: item.productVariant.product.slug
                                    }) }}" class="hover:underline">{{ item }}</a>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                </div>
            {% endfor %}
        {% endif %}
    </div>

</div>
{% endblock %}
