{% extends 'base.html.twig' %}

{% block meta %}
    <meta name="description" content="{{ product.name }} - {{ product.description|striptags|slice(0, 160) }}">
    <meta name="og:title" content="{{ product.name }} | EasyFit">
    <meta name="og:description" content="{{ product.description|striptags|slice(0, 160) }}">
{% endblock %}

{% block title %}{{ title }} | EasyFit{% endblock %}

{% block body %}

{# Fil d'ariane #}
<div class="px-4 mb-4">
    <p><a href="{{ path('app_home') }}">Accueil</a> > <a href="{{ path('app_product', {categorySlug: product.category.slug}) }}">{{ product.category }}</a></p>
</div>

<div class="flex flex-col items-center w-full px-4 py-8">

    {# Images et détails du produit #}
    <div class="lg:flex max-w-screen-2xl w-full">

        {# Galerie photos (2 premières images) #}
        <div class="flex lg:w-2/3 gap-2 justify-center">
            {% for image in product.productImages %}
                {% if loop.index <= 2 %}
                    <div class="overflow-hidden">
                        <img
                            src="{{ image.url }}"
                            alt="{{ image.altText }}"
                            class="lg:h-[80vh] object-cover transition-transform duration-500 hover:scale-120"
                        >
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        {# Informations et ajout au panier #}
        <div class="px-4 lg:w-1/3">

            <div class="mb-4">
                <h1 class="text-4xl font-semibold">{{ product.name }}</h1>

                {# Note moyenne #}
                <div class="my-2">
                    {% for i in 1..5 %}
                        {{ i <= product.averageRating ? '★' : '☆' }}
                    {% endfor %}
                    {{ product.getReviewsCount }} avis
                </div>

                <p class="font-bold">{{ product.price|format_currency('EUR', {rounding_mode: 'floor'}) }}</p>
            </div>

            {# Description du produit #}
            <div class="text-sm text-gray-700 mb-4">{{ product.description|raw }}</div>

            {# Messages d'erreur (ex: variante indisponible) #}
            {% for message in app.flashes('error') %}
                <div class="text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-2 mb-4">
                    {{ message }}
                </div>
            {% endfor %}

            {# Formulaire d'ajout au panier #}
            <form action="{{ path('app_cart_add') }}" method="POST">

                {# Sélection de la taille #}
                <div class="flex flex-col mb-4">
                    <label for="size-selector" class="font-semibold mb-1">Taille :</label>
                    <select name="size" id="size-selector" class="w-full bg-gray-100 rounded-lg px-3 py-1">
                        <option value="">-- Choisir une taille --</option>
                        {% for size in product.size %}
                            <option value="{{ size.id }}">{{ size }}</option>
                        {% endfor %}
                    </select>
                </div>

                {# Sélection de la couleur #}
                <div class="flex flex-col mb-4">
                    <label for="color-selector" class="font-semibold mb-1">Couleur :</label>
                    <select name="color" id="color-selector" class="w-full bg-gray-100 rounded-lg px-3 py-1">
                        <option value="">-- Choisir une couleur --</option>
                        {% for color in product.color %}
                            <option value="{{ color.id }}">{{ color }}</option>
                        {% endfor %}
                    </select>
                </div>

                <input type="hidden" name="product" value="{{ product.id }}">
                <button type="submit" class="w-full text-white font-semibold bg-green-600 mt-4 px-4 py-2 rounded-full hover:bg-green-700">
                    AJOUTER AU PANIER
                </button>

            </form>

        </div>
    </div>

    {# Section avis clients #}
    <div class="w-full max-w-screen-2xl mt-8">
        <h2 class="text-3xl font-semibold">Avis</h2>

        <div class="lg:flex lg:flex-row">

            {# Liste des avis existants #}
            <div class="my-4 lg:w-1/2">
                {% if product.reviews is empty %}
                    <p>Aucun avis pour le moment.</p>
                {% else %}
                    {% for review in product.reviews %}
                        <div class="border-b border-gray-200 mt-4 pb-2">
                            <span class="font-semibold">{{ review.user.firstname }} {{ review.user.lastname }}</span>
                            <span class="ml-2">
                                {% for i in 1..5 %}
                                    {{ i <= review.rating ? '★' : '☆' }}
                                {% endfor %}
                            </span>
                            <p class="mt-1">{{ review.comment }}</p>
                            <p class="text-xs text-gray-500 mt-1">Publié le {{ review.createdAt|date('d/m/Y') }}</p>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>

            {# Formulaire de dépôt d'avis #}
            <div class="flex justify-center items-center py-8 lg:w-1/2">
                <div class="w-full max-w-md border rounded-2xl p-8 bg-white">
                    <h2 class="text-2xl font-semibold text-center mb-4">Donner son avis</h2>
                    {{ form_start(form) }}

                        {# Note #}
                        <div class="mb-4">
                            {{ form_label(form.rating, 'Note', {'label_attr': {'class': 'text-xl font-semibold'}}) }}
                            {{ form_widget(form.rating, {'attr': {'class': 'w-full bg-gray-100 rounded-lg px-3 py-1'}}) }}
                        </div>

                        {# Commentaire #}
                        <div class="mb-4">
                            {{ form_label(form.comment, 'Votre avis', {'label_attr': {'class': 'text-xl font-semibold'}}) }}
                            {{ form_widget(form.comment, {'attr': {'class': 'w-full bg-gray-100 rounded-lg px-3 py-1'}}) }}
                        </div>

                        {{ form_widget(form.submit, {'attr': {'class': 'w-full text-white bg-green-600 px-4 py-2 rounded-full hover:bg-green-700'}}) }}

                    {{ form_end(form) }}
                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}
