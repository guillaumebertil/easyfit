{% extends 'base.html.twig' %}

{% block title %}Catalogue | EasyFit{% endblock %}

{% block body %}
    <div class="flex">
        <div>
            <img src="{{ product.productImages.first.url }}" alt="{{ product.productImages.first.altText }}">
        </div>

        <div>
            <h1 class="text-2xl font-semibold">{{ product.name }}</h1>
            {{ product.price|format_currency('EUR', {rounding_mode: 'floor'}) }}
            <p>{{ product.description|raw }}</p>
            <p>Tailles disponibles :</p>
            {% for size in product.size %}
                <p>{{ size }}</p>
            {% endfor %}

            {% for color in product.color %}
                {{ color }}
            {% endfor %}
            
        </div>
    </div>
{% endblock %}
