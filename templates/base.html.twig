<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        {% block meta %}
            <meta name="description" content="EasyFit - Des vêtements de sport confortables conçus pour bouger avec vous.">
            <meta name="og:title" content="EasyFit">
            <meta name="og:description" content="EasyFit - Des vêtements de sport confortables conçus pour bouger avec vous.">
        {% endblock %}

        <title>{% block title %}EasyFit!{% endblock %}</title>
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css')}}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

    </head>
    <body class="min-h-screen flex flex-col">
        {% include "partials/_header.html.twig" %}

        <main class="flex flex-1 flex-col items-center w-full text-gray-900 bg-gray-50">
            <div class="w-full max-w-screen-2xl mt-4">
                {% block body %}{% endblock %}
            </div>
        </main>

        {% include "partials/_footer.html.twig" %}
    </body>
</html>