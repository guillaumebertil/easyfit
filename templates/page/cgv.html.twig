{% extends 'base.html.twig' %}

{% block title %}{{ title }} | EasyFit{% endblock %}

{% block body %}
{# Fil d'ariane #}
<div class="px-4 mb-4">
    <p><a href="{{ path('app_home') }}">&lt; Retour</a></p>
</div>

<div class="flex flex-col items-center w-full px-4 py-8">
    {# En-tête #}
    <div class="max-w-2xl mb-8">
        <h1 class="text-4xl text-center font-semibold">{{ title }}</h1>
    </div>

    {# Article 1 - Objet #}
    <section class="w-full mb-4">
        <h2 class="text-2xl font-semibold">Article 1 - Objet</h2>
        <p>
            Les présentes conditions générales de vente régissent les relations contractuelles entre EasyFit et ses clients.
        </p>
    </section>

    {# Article 2 - Prix #}
    <section class="w-full mb-4">
        <h2 class="text-2xl font-semibold">Article 2 - Prix</h2>
        <p>
            Les prix sont indiqués en euros toutes taxes comprises. EasyFit se réserve le droit de modifier ses prix à tout moment.
        </p>
    </section>

    {# Article 3 - Commande #}
    <section class="w-full mb-4">
        <h2 class="text-2xl font-semibold">Article 3 - Commande</h2>
        <p>
            Toute commande implique l'acceptation des présentes CGV. La commande est validée après confirmation du paiement.
        </p>
    </section>

    {# Article 4 - Livraison #}
    <section class="w-full mb-4">
        <h2 class="text-2xl font-semibold">Article 4 - Livraison</h2>
        <p>
            Les délais de livraison sont de 3 à 5 jours ouvrés. Les frais de livraison sont calculés lors de la commande.
        </p>
    </section>

    {# Article 5 - Retours #}
    <section class="w-full mb-4">
        <h2 class="text-2xl font-semibold">Article 5 - Retours</h2>
        <p>
            Vous disposez de 14 jours à compter de la réception pour retourner un article dans son état d'origine. Les frais de retour sont à la charge du client.
        </p>
    </section>

    {# Article 6 - Service client #}
    <section class="w-full mb-4">
        <h2 class="text-2xl font-semibold">Article 6 - Service client</h2>
        <p>
            Pour toute question : <a href="mailto:contact@easyfit.fr" class="underline">contact@easyfit.fr</a>
        </p>
    </section>
</div>
{% endblock %}
